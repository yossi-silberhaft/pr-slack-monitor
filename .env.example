# GitHub personal access token with `repo` scope (or `public_repo` for public repos only).
# Create at: https://github.com/settings/tokens
PR_MONITOR_GH_TOKEN=ghp_your_token_here

# Slack incoming webhook URL.
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Your GitHub login (the username, not your display name).
GITHUB_USERNAME=your-github-username

# Absolute path to the `node` binary. Set automatically by setup.sh so cron can
# find node without inheriting your shell PATH. Override if needed.
NODE_BIN=/usr/local/bin/node
